# MiriTankr Backend Configuration

# Database URL (use postgresql+asyncpg for PostgreSQL connections)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/miritankr

# Secret key for JWT signature (change in production)
SECRET_KEY=SUPER_SECRET_KEY_FOR_LOCAL_DEV_CHANGE_IN_PROD_12345

# Token lifetime configuration
ACCESS_TOKEN_EXPIRE_MINUTES=10080
